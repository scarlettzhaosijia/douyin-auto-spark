# 本机 Chrome 或 Chromium 浏览器可执行文件路径，可选。
# 不配置时使用 Playwright 默认浏览器。
PLAYWRIGHT_BROWSER_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

# 是否使用无头模式，默认 true。
# 如需看到浏览器窗口，请改为 false。
PLAYWRIGHT_HEADLESS=true

# 发送完成后是否自动关闭浏览器，默认 true。
# 如需按回车后再关闭，请改为 false。
AUTO_CLOSE=true

# 是否在问候语末尾追加火花天数，默认开启；改为 false 可关闭。
SPARK_DAYS_ENABLED=true

# 火花开始日期，可选。配置后会按北京时间自动计算“已续火花 X 天”。
# 例如 2026-06-20 到 2026-07-12 会显示“已续火花23天”。
# SPARK_START_DATE=2026-06-20

# 手动指定火花天数，可选。配置后优先级高于 SPARK_START_DATE。
# SPARK_DAYS=23

# 要发送消息的抖音会话名称，必须是一整行 JSON 字符串数组。
DOUYIN_TARGET_NAMES='["暮邵落白"]'

# 抖音 Cookie，使用 https://chromewebstore.google.com/detail/cookie-editor/hlkenndednhfkekhgcdicdfddnkalmdm 浏览器插件，进入 https://www.douyin.com/chat ，并点击 export -> json 获取
DOUYIN_COOKIE='[{"domain":".douyin.com","expirationDate":1800175766.87008,"hostOnly":false,"httpOnly":false,"name":"UIFID","path":"/","sameSite":"no_restriction","secure":true,"session":false,"storeId":null,"value":"替换成真实 Cookie 值"}]'
